# API / local services
PORT=8787
DATABASE_URL=postgres://curacuri:curacuri@localhost:5432/curacuri
REDIS_URL=redis://localhost:6379

# OpenAI Compatible LLM
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.5
LLM_TIMEOUT_MS=30000
LLM_CONCURRENCY=2
LLM_RESPONSE_FORMAT=json_object

# OpenAI Compatible Embeddings for manual knowledge RAG.
# If omitted, EMBEDDING_API_KEY and EMBEDDING_BASE_URL fall back to LLM_API_KEY / LLM_BASE_URL.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Discord real connection
DISCORD_TOKEN=
DISCORD_DRY_RUN=true

# Discord real-connection verification with a separate tester bot.
# Keep disabled unless you are running a local/dogfood validation server.
CURACURI_ENV=local
DISCORD_TEST_ALLOW_BOT_AUTHORS=false
DISCORD_TEST_ALLOWED_BOT_AUTHOR_IDS=

# SaseQ/discord-mcp tester bot server.
# This token must be for the tester bot, not the curacuri.ai bot.
DISCORD_MCP_TOKEN=
DISCORD_MCP_GUILD_ID=
DISCORD_MCP_PORT=8085
